from pyspark.sql.functions import when, avg

# Create social_media_category
df = df.withColumn("social_media_category",
    when(df["social_media_hours"] < 2, "Low") \
    .when((df["social_media_hours"] >= 2) & (df["social_media_hours"] <= 5), "Medium") \
    .otherwise("High")
)

# Create gaming_category
df = df.withColumn("gaming_category",
    when(df["gaming_hours"] < 1, "Low") \
    .when((df["gaming_hours"] >= 1) & (df["gaming_hours"] <= 3), "Medium") \
    .otherwise("High")
)

# Group by digital habit categories and calculate averages
digital_habits_impact = df.groupBy('social_media_category', 'gaming_category').agg(
    avg('exam_score').alias('average_exam_score_by_digital_habits'),
    avg('productivity_score').alias('average_productivity_score_by_digital_habits')
)

print("Impact of Digital Habits on Performance:")
digital_habits_impact.show()
